    <Window x:Class="kursovaWithGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:kursovaWithGUI"
        mc:Ignorable="d"
        Title="Sort Application" Height="880" Width="400">

    <Grid Margin="20">
        <StackPanel HorizontalAlignment="Stretch">

            <TextBlock Text="Array settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

            <TextBlock Text="Size of array" Margin="0,0,0,5"/>
            <TextBlock Text="(min: 100; max: 50000)" FontSize="11" Foreground="Gray" Margin="0,0,0,5"/>
            <TextBox Name="textSize" Height="25" Margin="0,0,0,10"/>

            <TextBlock Text="Minimal element:" Margin="0,0,0,5"/>
            <TextBlock Text="(min: -1e7; max: 1e7; precision: 1e-5)" FontSize="11" Foreground="Gray" Margin="0,0,0,5"/>
            <TextBox Name="textMin" Height="25" Margin="0,0,0,10"/>

            <TextBlock Text="Maximum element:" Margin="0,0,0,5"/>
            <TextBlock Text="(min: must be greater than Minimal element; max: 1e7; precision: 1e-5)" FontSize="11" Foreground="Gray" Margin="0,0,0,5"/>
            <TextBox Name="textMax" Height="25" Margin="0,0,0,20"/>

            <TextBlock Text="Choose type of array" Margin="0,0,0,5"/>
            <ComboBox Name="AlgorithmsDirection" Height="30" Margin="0,0,0,10">
                <ComboBoxItem Content="Random" IsSelected="True"/>
                <ComboBoxItem Content="Ascending"/>
                <ComboBoxItem Content="Descending"/>
            </ComboBox>

            <Button Name="buttonGenerateClick" Content="Generate Array" Height="35" Click="btnGenerateClick" 
                    Background="Orange" Foreground="White" FontSize="14" FontWeight="Bold"/>

            <Label Height="25"/>

            <TextBlock Text="Choose Algorithm" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

            <ComboBox Name="chooseAlgorithms" Height="30" Margin="0,0,0,10">
                <ComboBoxItem Content="Counting Sort" IsSelected="True"/>
                <ComboBoxItem Content="Radix Sort"/>
                <ComboBoxItem Content="Bucket Sort"/>
                <ComboBoxItem Content="Flash Sort"/>
            </ComboBox>

            <Border Background="#FFFFEEBA" BorderBrush="#FFFFD500" BorderThickness="1" CornerRadius="3" Margin="0,0,0,15" Padding="5">
                <TextBlock Text="Counting Sort has a strict memory limit. If the range (Max - Min) is too large, it will fail safely." 
                       FontSize="11" Foreground="#FF856404" TextWrapping="Wrap"/>
            </Border>
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <RadioButton Name="rbAsc" Content="Ascending" IsChecked="True" Margin="0,0,20,0"/>
                <RadioButton Name="rbDesc" Content="Descending"/>
            </StackPanel>

            <Button Name="btnSort" Content="Sort" Height="40" Click="btnSortClick"
                    Background="#FF28A745" Foreground="White" FontSize="14" FontWeight="Bold" Cursor="Hand"/>

            <GroupBox Header="Results" Margin="0,20,0,0" Padding="10">
                <StackPanel>
                    <TextBlock Name="lblTime" Text="Time: ---" FontSize="14" Margin="0,5"/>
                    <TextBlock Name="lblCompares" Text="Compare: ---" FontSize="14" Margin="0,5"/>
                    <TextBlock Name="lblSwaps" Text="Swaps: ---" FontSize="14" Margin="0,5"/>
                </StackPanel>
            </GroupBox>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,0">

                <Button Name="btnDrawChart" Content="Draw Chart" Height="35" Width="150" Margin="0,0,15,0" 
                        Click="btnDrawChartClick" Background="#FF17A2B8" Foreground="White" FontWeight="Bold" Cursor="Hand"
                        ToolTip="Generate Bar Charts based on current session results"/>

                <Button Name="btnExit" Content="Exit" Height="35" Width="100" 
                        Click="btnExitClick" Background="#FFDC3545" Foreground="White" FontWeight="Bold" Cursor="Hand"
                        ToolTip="Close the application"/>

            </StackPanel>
            
        </StackPanel>
    </Grid>
</Window>